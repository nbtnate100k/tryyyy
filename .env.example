# Copy to .env and paste your token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Minimum top-up in USD (default is 1; cannot be below $1). Example: MIN_TOPUP_USD=5
# MIN_TOPUP_USD=1

# 2.0 reply-keyboard "Channel" button (default in code: https://t.me/lynchemleads)
# PUBLIC_CHANNEL_URL=https://t.me/lynchemleads
# Or username only (no https) if you didn't set PUBLIC_CHANNEL_URL:
# TELEGRAM_CHANNEL_USERNAME=lynchemleads

# Optional: shown on crypto checkout (demo invoices)
# PAYMENT_BTC_ADDRESS=
# PAYMENT_LTC_ADDRESS=
# PAYMENT_ETH_ADDRESS=

# Sendout + admin commands (/clearbin, /addbin, /admin, /panel) + top-up Accept/Reject
# UPLOAD_NOTIFY_CHAT_ID=123456789
# ADMIN_TELEGRAM_IDS=111222333,444555666
#
# PAYMENT_BTC_ADDRESS=
# PAYMENT_LTC_ADDRESS=
# PAYMENT_ETH_ADDRESS=
# UPLOAD_SERVER_PORT=8787
#
# Railway / cloud (see README):
# PORT is set by the host — Flask binds 0.0.0.0 and uses it automatically.
# LEADBOT_DATA_DIR=/data   # mount a volume so users.json / catalog / bin_leads persist
# SKIP_SINGLE_INSTANCE=1  # optional if you need to bypass the local port lock
#
# If set, POST /api/sync-groups and /api/sendout require HTTP header X-Leadbot-Secret (same value).
# Configure the BIN tool page to send it (saved locally in the browser) so random people can’t push stock.
# LEADBOT_API_SECRET=your-long-random-string
